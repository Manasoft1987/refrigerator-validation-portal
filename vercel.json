{
  "version": 2,
  "buildCommand": "npm run verify:deploy",
  "outputDirectory": "dist/public",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index?__path=/api/:path*"
    },
    {
      "source": "/storage/:path*",
      "destination": "/api/index?__path=/storage/:path*"
    },
    {
      "source": "/manus-storage/:path*",
      "destination": "/api/index?__path=/manus-storage/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 60,
      "memory": 1024,
      "includeFiles": "server/{fonts,assets}/**"
    }
  }
}
