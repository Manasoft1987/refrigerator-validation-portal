# App/session
JWT_SECRET=replace-with-long-random-secret
VITE_APP_ID=
PORTAL_ADMIN_PASSWORD=replace-with-strong-temporary-admin-password

# OAuth login (required for production login)
OAUTH_SERVER_URL=
VITE_OAUTH_PORTAL_URL=

# Database: MySQL-compatible connection string
DATABASE_URL=mysql://user:password@host:3306/database

# File storage for PDFs, uploaded logger files, logos, and generated images.
# Supabase Storage S3 example:
# S3_REGION=<project_region>
# S3_ENDPOINT=https://<project_ref>.storage.supabase.co/storage/v1/s3
# S3_BUCKET=<bucket_name>
# S3_FORCE_PATH_STYLE=true
STORAGE_PROVIDER=s3
S3_REGION=auto
S3_ENDPOINT=https://your-s3-compatible-endpoint
S3_BUCKET=refrigerator-validation-portal
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true

# Optional: keep compatibility with Manus storage while migrating
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
STORAGE_MIRROR_PROVIDER=
